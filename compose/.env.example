# PrivateNexus — environment template
# Copy to .env and fill in real values. Never commit .env.

# Keycloak OIDC
KEYCLOAK_URL=https://auth.example.com
KEYCLOAK_REALM=privatenexus
KEYCLOAK_CLIENT_ID=privatenexus

# Application
APP_URL=https://privatenexus.example.com
NODE_ENV=production
SESSION_COOKIE_DOMAIN=privatenexus.example.com

# Health checks
HEALTH_CHECK_INTERVAL_MS=60000
HEALTH_PROBE_TIMEOUT_MS=8000

# Monitoring (optional — enables cert expiry in Admin board)
PROMETHEUS_URL=http://10.10.50.104:9090
